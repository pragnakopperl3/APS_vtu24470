import java.util.*;

class Solution {
    public List<List<Integer>> combine(int n, int k) {
        List<List<Integer>> result = new ArrayList<>();
        backtrack(result, new ArrayList<>(), 1, n, k);
        return result;
    }

    private void backtrack(List<List<Integer>> result, List<Integer> tempList, int start, int n, int k) {
        // Base case: If the list size is k, we found a valid combination
        if (tempList.size() == k) {
            result.add(new ArrayList<>(tempList));
            return;
        }

        // Optimization: i <= n - (k - tempList.size()) + 1
        // This prevents searching branches where there aren't enough numbers left to reach k
        for (int i = start; i <= n; i++) {
            // 1. Choose: Add the number
            tempList.add(i);

            // 2. Explore: Move to the next number
            backtrack(result, tempList, i + 1, n, k);

            // 3. Un-choose: Backtrack
            tempList.remove(tempList.size() - 1);
        }
    }
}
