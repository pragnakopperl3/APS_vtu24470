class Solution {
    public int uniquePaths(int m, int n) {
        // We only need a 1D array to store the number of paths for the current row
        int[] row = new int[n];
        
        // Initialize the first row with 1s
        Arrays.fill(row, 1);
        
        // Iterate through the rest of the rows
        for (int i = 1; i < m; i++) {
            for (int j = 1; j < n; j++) {
                // row[j] is the value from the row above
                // row[j-1] is the value from the left in the current row
                row[j] = row[j] + row[j-1];
            }
        }
        
        return row[n - 1];
    }
}
