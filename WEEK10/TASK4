import java.util.Arrays;

class Solution {
    public int findMinArrowShots(int[][] points) {
        if (points.length == 0) return 0;

        // Sort by the end coordinate (index 1)
        // Note: Use Integer.compare to avoid potential overflow issues with (a[1] - b[1])
        Arrays.sort(points, (a, b) -> Integer.compare(a[1], b[1]));

        int arrows = 1;
        int currentEnd = points[0][1];

        for (int i = 1; i < points.length; i++) {
            // If the current balloon starts AFTER the current arrow's position
            if (points[i][0] > currentEnd) {
                arrows++;
                // Move the arrow to the end of the current balloon
                currentEnd = points[i][1];
            }
        }

        return arrows;
    }
}
