public class Solution {
    // you need treat n as an unsigned value
    public int reverseBits(int n) {
        int result = 0;
        for (int i = 0; i < 32; i++) {
            // 1. Shift the result to the left to make room for the next bit
            result <<= 1;
            
            // 2. Extract the least significant bit of n and add it to result
            // (n & 1) gets the last bit
            result += (n & 1);
            
            // 3. Shift n to the right to process the next bit
            n >>= 1;
        }
        return result;
    }
}
