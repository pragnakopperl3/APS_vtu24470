class Solution {
    public String longestNiceSubstring(String s) {
        if (s.length() < 2) return "";
        
        // Use a Set to store all characters present in the current string
        Set<Character> charSet = new HashSet<>();
        for (char c : s.toCharArray()) {
            charSet.add(c);
        }
        
        for (int i = 0; i < s.length(); i++) {
            char c = s.charAt(i);
            // If both cases of the character are present, continue
            if (charSet.contains(Character.toLowerCase(c)) && 
                charSet.contains(Character.toUpperCase(c))) {
                continue;
            }
            
            // If one case is missing, split the string at this index 
            // and recurse on both halves
            String left = longestNiceSubstring(s.substring(0, i));
            String right = longestNiceSubstring(s.substring(i + 1));
            
            // Return the longer of the two substrings (prefer left if equal)
            return left.length() >= right.length() ? left : right;
        }
        
        // If the loop completes, the entire string is nice
        return s;
    }
}
