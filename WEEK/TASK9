====257. Binary Tree Paths
class Solution {
    public List<String> binaryTreePaths(TreeNode root) {
        List<String> result = new ArrayList<>();
        if (root == null) return result;
        
        buildPaths(root, new StringBuilder(), result);
        return result;
    }

    private void buildPaths(TreeNode node, StringBuilder path, List<String> result) {
        if (node == null) return;

        int lengthBeforeAppend = path.length();
        path.append(node.val);

        // If it's a leaf, add the complete path to our result list
        if (node.left == null && node.right == null) {
            result.add(path.toString());
        } else {
            // If not a leaf, add the arrow and recurse
            path.append("->");
            buildPaths(node.left, path, result);
            buildPaths(node.right, path, result);
        }

        // Backtrack: Reset the StringBuilder to its state before this node was added
        path.setLength(lengthBeforeAppend);
    }
}
