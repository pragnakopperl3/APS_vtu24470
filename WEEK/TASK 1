class Solution {
    public boolean isSameTree(TreeNode p, TreeNode q) {
        // 1. Both are null: they are identical
        if (p == null && q == null) {
            return true;
        }
        
        // 2. One is null but the other isn't: not identical
        // 3. Values are different: not identical
        if (p == null || q == null || p.val != q.val) {
            return false;
        }
        
        // 4. Check if both left and right subtrees are identical
        return isSameTree(p.left, q.left) && isSameTree(p.right, q.right);
    }
}
